{
  "name": "qris-dinamis",
  "version": "2.0.0",
  "description": "QRIS Static to Dynamic converter — parse, validate, and convert Indonesian QRIS payment codes",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && npm run build:server",
    "build:server": "esbuild src/app-factory.ts --bundle --platform=node --format=esm --outfile=dist-server/app-factory.js --packages=external",
    "preview": "vite preview",
    "cli": "tsx src/cli.ts",
    "start": "tsx src/main.ts",
    "gateway": "tsx src/main.ts",
    "gateway:dev": "tsx watch src/main.ts",
    "test": "tsx --test src/**/*.test.ts"
  },
  "keywords": [
    "qris",
    "qr-code",
    "payment",
    "indonesia",
    "emvco",
    "gpn"
  ],
  "author": "Gidhan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/verssache/qris-dinamis"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsqr": "^1.4.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
