# Your merchant STATIC QRIS string (the whole EMVCo payload, tag 00..63)
STATIC_QRIS=

# Shared secret; must match the API Key configured in the NotificationListener app
API_KEY=change-me

# Admin console (/admin). Leave unset to keep the console disabled entirely.
# Set a strong password to enable login + transaction/integration monitoring.
ADMIN_PASSWORD=
# Optional: dedicated session-cookie signing key. Defaults to ADMIN_PASSWORD.
ADMIN_SESSION_SECRET=

# Optional
PORT=3000
INVOICE_TTL_MS=600000
MAX_OFFSET=999
